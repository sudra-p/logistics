# =============================================================================
# Django Settings
# =============================================================================
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=your-domain.com,your-ip

# =============================================================================
# Database (remote PostgreSQL on DB EC2 instance)
# =============================================================================
DB_NAME=logistics
DB_USER=logistics_user
DB_PASSWORD=your-db-password
DB_HOST=10.0.1.xx  # Private IP of DB EC2 instance
DB_PORT=5432

# =============================================================================
# Celery (Redis running locally via Docker Compose)
# =============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# =============================================================================
# AWS Credentials
# =============================================================================
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
AWS_S3_BUCKET_NAME=your-bucket-name
AWS_S3_REGION=ap-south-1

# =============================================================================
# AWS SES (Email)
# =============================================================================
AWS_SES_REGION=ap-south-1
AWS_SES_FROM_EMAIL=noreply@your-domain.com

# =============================================================================
# Email Distribution List
# =============================================================================
DISTRIBUTION_LIST=ops@company.com,cs@company.com
